# Auth0 (Secure Agent Identity)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=          # Confidential app (client_credentials, CIBA, Token Vault)
AUTH0_CLIENT_SECRET=
AUTH0_DEVICE_CLIENT_ID=   # Native app for device flow (public, no secret needed)
AUTH0_AUDIENCE=https://deepsentinel.local/api

# GitHub (via Auth0 Token Vault or direct PAT)
GITHUB_TOKEN=ghp_your_token

# Slack Bot Token
SLACK_BOT_TOKEN=xoxb-your-token

# Macroscope (Codebase Intelligence)
MACROSCOPE_API_KEY=
MACROSCOPE_WORKSPACE_ID=

# Ghost (Persistent Postgres)
GHOST_CONNECTION_STRING=postgresql://ghost:pass@db.ghost.build/postgres
GHOST_DB_ID=

# TrueFoundry (AI Gateway)
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_BASE_URL=https://gateway.truefoundry.ai

# Overmind (Prompt Optimization)
OVERMIND_API_KEY=ovr_

# Aerospike (Real-time Cache)
AEROSPIKE_HOST=127.0.0.1
AEROSPIKE_PORT=3000

# OpenAI (fallback)
OPENAI_API_KEY=sk-
